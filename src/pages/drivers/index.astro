---
import DriverExplorer from "../../components/DriverExplorer.svelte";
import Layout from "../../components/Layout.astro";
---

<Layout
  title="Drivers"
  description="Browse and compare cone drivers, compression drivers and horns"
  preloadData={["/api/drivers.json", "/api/horns.json"]}
>
  <h1>Drivers</h1>
  <p class="subtitle">
    Cone drivers (Thiele–Small parameters), compression drivers (horn/throat specs) and horns
    (waveguides) in the database. Switch catalog with the tabs, then check up to 4 boxes and
    click <strong>Compare</strong> for a side-by-side table and radar chart.
  </p>
  <DriverExplorer client:only="svelte" />
</Layout>

<style>
  h1 {
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }
</style>
