---
import Layout from "../components/Layout.astro";
import StackBuilder from "../components/StackBuilder.svelte";
---

<Layout title="My Stack" description="Build a sound system and calculate coverage.">
  <h1>My Stack</h1>
  <p class="subtitle">Select enclosures by role, set quantities, and check coverage and crossover.</p>
  <StackBuilder client:only="svelte" />
</Layout>

<style>
  h1 {
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin-top: 0;
    margin-bottom: 1.5rem;
  }
</style>
