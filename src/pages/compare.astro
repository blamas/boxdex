---
import Compare from "../components/Compare.svelte";
import Layout from "../components/Layout.astro";
---

<Layout title="Compare" description="Overlay frequency response curves for multiple enclosure designs">
  <h1>Compare Enclosures</h1>
  <p class="subtitle">Overlay SPL, phase, or impedance curves. Select enclosures from the list below.</p>
  <Compare client:only="svelte" />
</Layout>

<style>
  h1 { margin-bottom: 0.5rem; }
  .subtitle {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }
</style>
