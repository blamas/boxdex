---
import DriverExplorer from "../../../components/DriverExplorer.svelte";
import Layout from "../../../components/Layout.astro";
import { localeStaticPaths, useLocale } from "../../../i18n";

export { localeStaticPaths as getStaticPaths };

const { t, localeBase } = useLocale(Astro.params);
---

<Layout
  title={t.pages.drivers.title}
  description={t.pages.drivers.description}
  preloadData={["/api/drivers.json", "/api/horns.json"]}
>
  <h1>{t.pages.drivers.heading}</h1>
  <p class="subtitle" set:html={t.pages.drivers.subtitle} />
  <DriverExplorer client:only="svelte" t={t.driverExplorer} localeBase={localeBase} />
</Layout>

<style>
  h1 {
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }
</style>
