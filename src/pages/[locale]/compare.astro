---
import Compare from "../../components/Compare.svelte";
import Layout from "../../components/Layout.astro";
import { localeStaticPaths, useLocale } from "../../i18n";

export { localeStaticPaths as getStaticPaths };

const { t } = useLocale(Astro.params);
---

<Layout
  title={t.pages.compare.title}
  description={t.pages.compare.description}
  preloadData={["/api/manifest.json", "/api/driver-options.json"]}
>
  <h1>{t.pages.compare.heading}</h1>
  <p class="subtitle">{t.pages.compare.subtitle}</p>
  <Compare client:only="svelte" t={t.compare} curveLabels={t.curveLabels} />
</Layout>

<style>
  h1 { margin-bottom: 0.5rem; }
  .subtitle {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }
</style>
