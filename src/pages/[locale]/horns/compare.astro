---
import HornCompare from "../../../components/HornCompare.svelte";
import Layout from "../../../components/Layout.astro";
import { localeStaticPaths, useLocale } from "../../../i18n";

export { localeStaticPaths as getStaticPaths };

const { t, localeBase } = useLocale(Astro.params);
---

<Layout
  title={t.pages.hornsCompare.title}
  description={t.pages.hornsCompare.description}
  preloadData={["/api/horns.json"]}
>
  <h1>{t.pages.hornsCompare.heading}</h1>
  <p class="subtitle">{t.pages.hornsCompare.subtitle}</p>
  <HornCompare client:only="svelte" t={t.hornCompare} tRadar={t.radarCompare} localeBase={localeBase} />
</Layout>

<style>
  h1 {
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }
</style>
