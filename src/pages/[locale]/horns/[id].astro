---
import { getCollection } from "astro:content";
import EnclosureList from "../../../components/EnclosureList.astro";
import Layout from "../../../components/Layout.astro";
import SpecTable from "../../../components/SpecTable.astro";
import { LOCALES, tt, useLocale } from "../../../i18n";
import { withUnit } from "../../../lib/format";

export async function getStaticPaths() {
  const horns = await getCollection("horns");
  const drivers = await getCollection("drivers");
  const enclosures = await getCollection("enclosures");
  return LOCALES.flatMap((locale) =>
    horns.map((entry) => ({
      params: { locale, id: entry.id },
      props: {
        entry,
        compatible: drivers
          .filter((d) => d.data.type === "compression" && d.data.exitInch === entry.data.exitInch)
          .sort((a, b) =>
            `${a.data.brand} ${a.data.model}`.localeCompare(`${b.data.brand} ${b.data.model}`)
          ),
        usedBy: enclosures
          .filter((e) =>
            e.data.driverProfiles.some((p) => p.drivers.some((x) => x.horn?.id === entry.id))
          )
          .sort((a, b) => a.data.name.localeCompare(b.data.name)),
      },
    }))
  );
}

const { entry, compatible, usedBy } = Astro.props;
const h = entry.data;

const { t, localeBase } = useLocale(Astro.params);
const sr = t.hornDetail.specRows;

const mouthAreaCm2 = Math.round((h.mouthWmm * h.mouthHmm) / 100);

const specRows: { label: string; value: string | undefined }[] = [
  { label: sr.throatExit, value: `${h.exitInch}"` },
  { label: sr.coverageHV, value: `${h.coverageHorizontalDeg}° × ${h.coverageVerticalDeg}°` },
  { label: sr.directivity, value: h.constantDirectivity ? sr.constantDirectivity : undefined },
  { label: sr.flareCutoff, value: withUnit(h.cutoffHz, "Hz") },
  { label: sr.mouth, value: `${h.mouthWmm} × ${h.mouthHmm} mm (≈ ${mouthAreaCm2} cm²)` },
  { label: sr.depth, value: withUnit(h.depthMm, "mm") },
  { label: sr.profile, value: h.profile },
  { label: sr.material, value: h.material },
  { label: sr.weight, value: withUnit(h.weightKg, "kg") },
];

const headline = `${h.exitInch}" exit · ${h.coverageHorizontalDeg}°×${h.coverageVerticalDeg}° · ${h.cutoffHz} Hz`;
const description = tt(t.hornDetail.metaDescription, { brand: h.brand, model: h.model });
---

<Layout title={`${h.brand} ${h.model}`} description={description}>
  <div class="detail">
    <header class="detail-header">
      <p class="crumb"><a href={`${localeBase}/drivers?tab=horn`}>← {t.hornDetail.allHorns}</a></p>
      <h1>{h.brand} {h.model}</h1>
      <p class="meta">
        {headline}
        {h.datasheetUrl && (
          <> · <a href={h.datasheetUrl} target="_blank" rel="noopener">{t.hornDetail.datasheetLink}</a></>
        )}
      </p>
    </header>

    <div class="detail-body">
      <section>
        <h2>{t.hornDetail.specifications}</h2>
        <SpecTable rows={specRows} />
      </section>

      <section>
        <h2>{t.hornDetail.compatibleCDs}</h2>
        {compatible.length > 0 ? (
          <ul class="driver-links">
            {compatible.map((d) => (
              <li>
                <a href={`${localeBase}/drivers/${d.id}`}>{d.data.brand} {d.data.model}</a>
                <span class="muted"> · {h.exitInch}" exit</span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="muted">{t.hornDetail.noCompatibleCDs}</p>
        )}
        <p class="provenance-note">
          {tt(t.hornDetail.matchedOnExit, { exit: h.exitInch })}
        </p>
      </section>

      <section>
        <h2>{t.hornDetail.usedIn} ({usedBy.length})</h2>
        {usedBy.length > 0 ? (
          <EnclosureList items={usedBy} />
        ) : (
          <p class="muted">{t.hornDetail.noUsedIn}</p>
        )}
      </section>
    </div>
  </div>
</Layout>

<style>
  .detail {
    max-width: 720px;
  }

  .detail-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--line);
  }

  .crumb {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    margin: 0 0 0.75rem;
  }

  h1 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-size: 1.1rem;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0;
  }

  /* --accent and --muted are near-identical luminance in light theme: underline keeps
     the datasheet link distinguishable from the surrounding muted text (WCAG 1.4.1). */
  .meta a {
    text-decoration: underline;
  }

  .detail-body {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .muted {
    color: var(--muted);
  }

  .driver-links {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
</style>
