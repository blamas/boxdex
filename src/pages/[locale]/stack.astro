---
import Layout from "../../components/Layout.astro";
import StackBuilder from "../../components/StackBuilder.svelte";
import { localeStaticPaths, useLocale } from "../../i18n";

export { localeStaticPaths as getStaticPaths };

const { t, localeBase } = useLocale(Astro.params);
---

<Layout
  title={t.pages.stack.title}
  description={t.pages.stack.description}
  preloadData={["/api/manifest.json"]}
>
  <h1>{t.pages.stack.heading}</h1>
  <p class="subtitle">{t.pages.stack.subtitle}</p>
  <p class="notice">
    {t.pages.stack.notice}
    {" "}<a href={`${localeBase}/help#model-limits`}>{t.pages.stack.noticeLimits}</a>.
    {" "}<a href={`${localeBase}/help#further`}>{t.pages.stack.noticeLink}</a>.
  </p>
  <StackBuilder client:only="svelte" t={t.stackBuilder} tSystemResponse={t.systemResponse} />
</Layout>

<style>
  h1 {
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .notice {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: #ffb347;
    background: color-mix(in srgb, #ff8c00 10%, transparent);
    border-left: 3px solid #ff8c00;
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.75rem;
    margin-top: 0;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  :global([data-theme="light"]) .notice {
    color: #7a5f00;
    background: #fff8d6;
    border-left-color: #e6b800;
  }

  .notice a {
    color: #ffe0a0;
    text-decoration: underline;
  }

  :global([data-theme="light"]) .notice a {
    color: #3d2800;
    font-weight: 700;
  }
</style>
