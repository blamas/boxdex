---
import Layout from "../../components/Layout.astro";
import { localeStaticPaths, useLocale } from "../../i18n";

export { localeStaticPaths as getStaticPaths };

const { t } = useLocale(Astro.params);

const { sections } = t.help;
const { using, glossary } = sections;

const { learn } = t.pages;

type ResourceEntry = { term: string; url: string; def: string };
type ResourceSection = { heading: string; [key: string]: ResourceEntry | string };

const furtherSections: [string, ResourceSection][] = [
  ["further-simulation", learn.simulation as ResourceSection],
  ["further-measurement", learn.measurement as ResourceSection],
  ["further-reading", learn.reading as ResourceSection],
  ["further-community", learn.community as ResourceSection],
];
---

<Layout
  title={t.pages.help.title}
  description={t.pages.help.description}
>
  <h1>{t.pages.help.title}</h1>

  <nav class="toc">
    <a href="#using">{t.help.toc.using}</a>
    <a href="#glossary">{t.help.toc.glossary}</a>
    <a href="#further">{t.help.toc.further}</a>
  </nav>

  <section class="help-section" id="using">
    <h2>{using.heading}</h2>

    <div class="feature-group">
      <h3>{using.finding.heading}</h3>
      <dl>
        <div class="entry" id="catalog">
          <dt>{using.finding.catalog.term}</dt>
          <dd>{using.finding.catalog.def}</dd>
        </div>
        <div class="entry" id="find">
          <dt>{using.finding.find.term}</dt>
          <dd>{using.finding.find.def}</dd>
        </div>
        <div class="entry" id="explore">
          <dt>{using.finding.explore.term}</dt>
          <dd>{using.finding.explore.def}</dd>
        </div>
      </dl>
    </div>

    <div class="feature-group">
      <h3>{using.comparing.heading}</h3>
      <dl>
        <div class="entry" id="compare">
          <dt>{using.comparing.compareEnclosures.term}</dt>
          <dd>{using.comparing.compareEnclosures.def}</dd>
        </div>
        <div class="entry" id="compare-drivers">
          <dt>{using.comparing.compareDrivers.term}</dt>
          <dd>{using.comparing.compareDrivers.def}</dd>
        </div>
      </dl>
    </div>

    <div class="feature-group">
      <h3>{using.driversHorns.heading}</h3>
      <dl>
        <div class="entry" id="drivers">
          <dt>{using.driversHorns.driverCatalog.term}</dt>
          <dd>{using.driversHorns.driverCatalog.def}</dd>
        </div>
        <div class="entry" id="substitutes">
          <dt>{using.driversHorns.substitutes.term}</dt>
          <dd>{using.driversHorns.substitutes.def}</dd>
        </div>
        <div class="entry" id="horn-matching">
          <dt>{using.driversHorns.hornMatching.term}</dt>
          <dd>{using.driversHorns.hornMatching.def}</dd>
        </div>
      </dl>
    </div>

    <div class="feature-group">
      <h3>{using.planningRig.heading}</h3>
      <dl>
        <div class="entry" id="stack">
          <dt>{using.planningRig.stackBuilder.term}</dt>
          <dd>{using.planningRig.stackBuilder.def}</dd>
        </div>
        <div class="entry" id="amp-matching">
          <dt>{using.planningRig.ampMatching.term}</dt>
          <dd>{using.planningRig.ampMatching.def}</dd>
        </div>
        <div class="entry" id="crossover-suggestions">
          <dt>{using.planningRig.crossoverSuggestions.term}</dt>
          <dd>{using.planningRig.crossoverSuggestions.def}</dd>
        </div>
        <div class="entry" id="system-response">
          <dt>{using.planningRig.systemResponse.term}</dt>
          <dd>{using.planningRig.systemResponse.def}</dd>
        </div>
      </dl>
    </div>

    <div class="feature-group">
      <h3>{using.dataProvenance.heading}</h3>
      <dl>
        <div class="entry" id="provenance-badges">
          <dt>{using.dataProvenance.measuredVsSim.term}</dt>
          <dd>{using.dataProvenance.measuredVsSim.def}</dd>
        </div>
        <div class="entry" id="exports">
          <dt>{using.dataProvenance.exports.term}</dt>
          <dd>{using.dataProvenance.exports.def}</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="help-section" id="glossary">
    <h2>{glossary.heading}</h2>
    <p class="section-subtitle">{glossary.subtitle}</p>

    <nav class="toc toc-glossary">
      <a href="#glossary-driver">{glossary.driver.heading}</a>
      <a href="#glossary-horns">{glossary.horns.heading}</a>
      <a href="#glossary-system">{glossary.system.heading}</a>
      <a href="#glossary-power">{glossary.power.heading}</a>
      <a href="#glossary-topologies">{glossary.topologies.heading}</a>
    </nav>

    <div class="glossary-group" id="glossary-driver">
      <h3>{glossary.driver.heading}</h3>
      <dl>
        {Object.entries(glossary.driver).filter(([k]) => k !== "heading").map(([id, entry]) => (
          <div class="entry" id={id.replace(/_/g, "-")}>
            <dt>{(entry as { term: string; def: string }).term}</dt>
            <dd>{(entry as { term: string; def: string }).def}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="glossary-group" id="glossary-horns">
      <h3>{glossary.horns.heading}</h3>
      <dl>
        {Object.entries(glossary.horns).filter(([k]) => k !== "heading").map(([id, entry]) => (
          <div class="entry" id={id.replace(/_/g, "-")}>
            <dt>{(entry as { term: string; def: string }).term}</dt>
            <dd>{(entry as { term: string; def: string }).def}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="glossary-group" id="glossary-system">
      <h3>{glossary.system.heading}</h3>
      <dl>
        {Object.entries(glossary.system).filter(([k]) => k !== "heading").map(([id, entry]) => (
          <div class="entry" id={id.replace(/_/g, "-")}>
            <dt>{(entry as { term: string; def: string }).term}</dt>
            <dd>{(entry as { term: string; def: string }).def}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="glossary-group" id="glossary-power">
      <h3>{glossary.power.heading}</h3>
      <dl>
        {Object.entries(glossary.power).filter(([k]) => k !== "heading").map(([id, entry]) => (
          <div class="entry" id={id.replace(/_/g, "-")}>
            <dt>{(entry as { term: string; def: string }).term}</dt>
            <dd>{(entry as { term: string; def: string }).def}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="glossary-group" id="glossary-topologies">
      <h3>{glossary.topologies.heading}</h3>
      <dl>
        {Object.entries(glossary.topologies).filter(([k]) => k !== "heading").map(([id, entry]) => (
          <div class="entry" id={id.replace(/_/g, "-")}>
            <dt>{(entry as { term: string; def: string }).term}</dt>
            <dd>{(entry as { term: string; def: string }).def}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="help-section" id="further">
    <h2>{learn.heading}</h2>
    <p class="section-subtitle">{learn.intro}</p>

    {furtherSections.map(([id, s]) => (
      <div class="feature-group">
        <h3>{s.heading}</h3>
        <dl>
          {Object.entries(s).filter(([k]) => k !== "heading").map(([, entry]) => {
            const r = entry as ResourceEntry;
            return (
              <div class="entry">
                <dt><a class="external" href={r.url} target="_blank" rel="noopener noreferrer">{r.term}</a></dt>
                <dd>{r.def}</dd>
              </div>
            );
          })}
        </dl>
      </div>
    ))}
  </section>
</Layout>

<style>
  h1 {
    margin-bottom: 0.5rem;
  }

  .toc {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin-bottom: 2.5rem;
  }

  .toc a + a::before {
    content: "·";
    color: var(--muted);
    padding: 0 0.6rem;
    display: inline-block;
  }

  .toc-glossary {
    margin-bottom: 1.5rem;
  }

  .help-section {
    margin-bottom: 3rem;
    scroll-margin-top: 1rem;
  }

  h2 {
    font-size: 1.1rem;
    color: var(--muted);
    margin-bottom: 1.25rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--line);
  }

  .section-subtitle {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin-top: -0.75rem;
    margin-bottom: 1.25rem;
  }

  .feature-group,
  .glossary-group {
    margin-bottom: 2rem;
  }

  h3 {
    font-size: 0.9rem;
    color: var(--text);
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
  }

  dl {
    margin: 0;
  }

  .entry {
    margin-bottom: 1rem;
    scroll-margin-top: 1rem;
  }

  dt {
    font-family: var(--font-mono);
    font-weight: 700;
    margin-bottom: 0.2rem;
    font-size: 0.9rem;
  }

  dd {
    margin: 0;
    line-height: 1.6;
    font-size: 0.95rem;
    color: var(--text);
    padding-left: 1rem;
    border-left: 2px solid var(--line);
  }

  a.external {
    color: var(--accent);
    text-decoration: none;
  }

  a.external:hover {
    text-decoration: underline;
  }
</style>
