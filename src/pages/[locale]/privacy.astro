---
import Layout from "../../components/Layout.astro";
import { localeStaticPaths, useLocale } from "../../i18n";
import { GIT_REPO_URL } from "../../lib/site";

export { localeStaticPaths as getStaticPaths };

const { t, localeBase } = useLocale(Astro.params);
const p = t.pages.privacy;
---

<Layout
  title={p.title}
  description={p.description}
>
  <article class="privacy prose">
    <h1>{p.title}</h1>

    <p class="intro">
      {p.introPre}{" "}
      <a href={`${localeBase}/about`}>{p.introLink}</a>{" "}
      {p.introPost}
    </p>

    <h2>{p.noCollection.heading}</h2>
    <p>{p.noCollection.body}</p>

    <h2>{p.localStorage.heading}</h2>
    <p>
      {p.localStorage.bodyPre}{" "}
      <a href="https://developer.mozilla.org/en-US/docs/Web/API/Window/localStorage" target="_blank" rel="noopener"><code>{p.localStorage.codeWord}</code></a>{p.localStorage.bodyPost}
    </p>

    <h2>{p.contribute.heading}</h2>
    <p>{p.contribute.optionalBody}</p>
    <p>
      {p.contribute.publicPre}{" "}
      <a href="https://docs.github.com/en/site-policy/privacy-policies/github-privacy-statement" target="_blank" rel="noopener">{p.contribute.publicLink}</a>{p.contribute.publicPost}
    </p>
    <p>
      {p.contribute.turnstilePre}{" "}
      <a href="https://developers.cloudflare.com/turnstile/" target="_blank" rel="noopener">{p.contribute.turnstileLink}</a>{p.contribute.turnstilePost}
    </p>
    <p>{p.contribute.storageBody}</p>

    <h2>{p.cloudflare.heading}</h2>
    <p>{p.cloudflare.intro}</p>
    <ul>
      {p.cloudflare.logs.map((item) => <li>{item}</li>)}
    </ul>
    <p>{p.cloudflare.note}</p>
    <p>{p.cloudflare.why}</p>
    <p>
      {p.cloudflare.mitigationPre}<a href="https://mullvad.net/" target="_blank" rel="noopener">Mullvad</a> · <a href="https://protonvpn.com/" target="_blank" rel="noopener">ProtonVPN</a>{p.cloudflare.mitigationMid}{" "}
      <a href="https://www.torproject.org/" target="_blank" rel="noopener">{p.cloudflare.torLinkText}</a>{" "}
      {p.cloudflare.mitigationPost}
    </p>
    <p>
      {p.cloudflare.policyPre}{" "}
      <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener">{p.cloudflare.policyLink}</a>{" "}
      {p.cloudflare.policyPost}
    </p>

    <h2>{p.rights.heading}</h2>
    <p>
      {p.rights.bodyPre}{" "}
      <a href={`${GIT_REPO_URL}/issues`} target="_blank" rel="noopener">{p.rights.issuesLink}</a>{p.rights.bodyPost}
    </p>

    <p class="easter-egg">
      {p.easterEgg.line1}<br />
      {p.easterEgg.line2}
    </p>
  </article>
</Layout>

<style>
  h1 {
    margin-bottom: 0.5rem;
  }

  .intro {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin-top: 0;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  /* --accent and --muted are near-identical luminance in light theme: underline keeps
     the inline link distinguishable from the surrounding muted text (WCAG 1.4.1). */
  .intro a {
    text-decoration: underline;
  }

  .easter-egg {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    margin-top: 2rem;
    line-height: 1.6;
  }

  h2 {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-size: 1rem;
    font-family: var(--font-mono);
    color: var(--accent);
  }

  p {
    color: var(--text);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  ul {
    margin: 0.25rem 0 0.75rem 1.25rem;
    padding: 0;
    color: var(--text);
    line-height: 1.7;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--muted);
  }

  a {
    color: var(--accent);
  }

  a code {
    color: var(--accent);
  }
</style>
