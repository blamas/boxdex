---
import { getImage, Image } from "astro:assets";
import { getCollection, getEntry, render } from "astro:content";
import BoxCurves from "../../../components/BoxCurves.svelte";
import EnclosureList from "../../../components/EnclosureList.astro";
import Layout from "../../../components/Layout.astro";
import { LOCALES, tt, useLocale } from "../../../i18n";
import { contactHref, contactLabel } from "../../../lib/contact";
import { humanize, withUnit } from "../../../lib/format";
import { deriveMetrics, provenanceOf } from "../../../lib/metrics";

export async function getStaticPaths() {
  const enclosures = await getCollection("enclosures");
  return LOCALES.flatMap((locale) =>
    enclosures.map((entry) => ({
      params: { locale, slug: entry.id },
      props: { entry },
    }))
  );
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;
const { specs, dims } = data;

const { t, localeBase } = useLocale(Astro.params);
const sr = t.enclosureDetail.specRows;

const metrics = deriveMetrics({
  netVolumeL: data.netVolumeL,
  dims: data.dims,
  weightKg: data.weightKg,
  specs: data.specs,
});

const provenance = provenanceOf(data.driverProfiles.flatMap((p) => p.measurements));

const availabilityLabels = t.enclosureDetail.availabilityLabels;
const contactChannels = t.enclosureDetail.contactChannels;
const availabilityLabel = data.availability
  ? (availabilityLabels[data.availability as keyof typeof availabilityLabels] ?? data.availability)
  : undefined;
// Non-free plans get the prominent "how to get these" framing; a free box just says "contact".
const nonFree = data.availability != null && data.availability !== "free";
const contactHeading = nonFree ? t.enclosureDetail.howToGetPlans : t.enclosureDetail.contact;
// `contact` has a schema default of [], but a stale content cache (schema-only edits in
// schemas.ts do not always bust it) can leave it undefined on a pre-existing entry.
const contactList = data.contact ?? [];

const specRows: { label: string; value: string | undefined }[] = [
  {
    label: sr.topology,
    value: humanize(data.topology) + (data.topologyVariant ? ` · ${data.topologyVariant}` : ""),
  },
  { label: sr.ways, value: data.ways !== undefined ? `${data.ways}-way` : undefined },
  { label: sr.buildComplexity, value: data.buildComplexity },
  { label: sr.netVolume, value: withUnit(metrics.volumeL, "L") },
  { label: sr.grossVolume, value: withUnit(data.grossVolumeL, "L") },
  { label: sr.dimensions, value: `${dims.hMm} × ${dims.wMm} × ${dims.dMm} mm` },
  { label: sr.footprint, value: withUnit(metrics.footprintCm2, "cm²") },
  { label: sr.weight, value: withUnit(data.weightKg, "kg") },
  { label: sr.f3, value: withUnit(specs.f3Hz, "Hz") },
  { label: sr.f6, value: withUnit(specs.f6Hz, "Hz") },
  { label: sr.fb, value: withUnit(specs.fbHz, "Hz") },
  { label: sr.f3High, value: withUnit(specs.f3HzHigh, "Hz") },
  { label: sr.maxSpl, value: withUnit(specs.maxSplDb, "dB") },
  { label: sr.maxSplExcursion, value: withUnit(specs.maxSplExcursionDb, "dB") },
  { label: sr.maxSplThermal, value: withUnit(specs.maxSplThermalDb, "dB") },
  { label: sr.sensitivity, value: withUnit(specs.sensitivityDb, "dB") },
  { label: sr.impedanceMin, value: withUnit(specs.impedanceMinOhm, "Ω") },
  {
    label: sr.coverageAngle,
    value: specs.coverageAngleDeg !== undefined ? `${specs.coverageAngleDeg}°` : undefined,
  },
  { label: sr.recommendedCrossover, value: withUnit(specs.recommendedCrossoverHz, "Hz") },
  { label: sr.hornCutoff, value: withUnit(specs.hornCutoffHz, "Hz") },
  { label: sr.hornMouth, value: withUnit(specs.hornMouthCm2, "cm²") },
  { label: sr.hornThroat, value: withUnit(specs.hornThroatCm2, "cm²") },
  { label: sr.recommendedPower, value: withUnit(specs.recommendedPowerW, "W") },
  { label: sr.powerAes, value: withUnit(specs.powerAesW, "W") },
  { label: sr.powerProgram, value: withUnit(specs.powerProgramW, "W") },
  { label: sr.maxPortVelocity, value: withUnit(specs.maxVelocityMs, "m/s") },
  { label: sr.outputDensity, value: withUnit(metrics.outputDensity, "dB/size") },
  { label: sr.plywoodThickness, value: withUnit(data.plywoodThicknessMm, "mm") },
  {
    label: sr.plywoodSheets,
    value:
      data.sheetCount !== undefined
        ? `${data.sheetCount}×${
            data.sheetSizeMm ? ` ${data.sheetSizeMm.wMm}×${data.sheetSizeMm.hMm} mm` : ""
          }`
        : undefined,
  },
  {
    label: sr.connectors,
    value: data.connectors.length > 0 ? data.connectors.join(", ") : undefined,
  },
];

// One resolved drivers table per profile, each row carrying its qty and (optional) cataloged
// horn alongside the driver entry.
const driverProfileTables = await Promise.all(
  data.driverProfiles.map(async (p) => ({
    id: p.id,
    rows: await Promise.all(
      p.drivers.map(async (e) => ({
        entry: await getEntry("drivers", e.driver.id),
        qty: e.qty,
        horn: e.horn ? await getEntry("horns", e.horn.id) : undefined,
      }))
    ),
  }))
);
const allEnclosures = await getCollection("enclosures");
// Union across every declared profile: a related box may only share a driver in an alternate build.
const thisDriverIds = new Set(
  data.driverProfiles.flatMap((p) => p.drivers.map((e) => e.driver.id))
);
const relatedEnclosures = allEnclosures
  .filter(
    (e) =>
      e.id !== entry.id &&
      e.data.driverProfiles.some((p) => p.drivers.some((x) => thisDriverIds.has(x.driver.id)))
  )
  .sort((a, b) => a.data.name.localeCompare(b.data.name));

const allPdfGlob = import.meta.glob("/data/enclosures/**/*.pdf", {
  query: "?url",
  import: "default",
  eager: true,
}) as Record<string, string>;

const planUrls = data.plans.map((filename) => {
  const key = `/data/enclosures/${entry.id}/${filename}`;
  return { filename, url: allPdfGlob[key] ?? null };
});

const allSourceGlob = import.meta.glob("/data/enclosures/**/*", {
  query: "?url",
  import: "default",
  eager: true,
}) as Record<string, string>;

const sourceFiles = data.sources.map((s) => {
  const key = `/data/enclosures/${entry.id}/${s.file}`;
  return { ...s, url: allSourceGlob[key] ?? null };
});

const heroImage = data.images[0];
// Full-resolution sources for the lightbox carousel, indexed to match data.images (hero is index 0).
const lightboxImages = await Promise.all(
  data.images.map(async (img, i) => {
    const full = await getImage({ src: img, width: Math.min(img.width, 1600) });
    return {
      src: full.src,
      alt: i === 0 ? data.name : tt(t.enclosureDetail.photoAlt, { name: data.name, n: i + 1 }),
    };
  })
);
const hasCurves = data.driverProfiles.some(
  (p) => p.measurements.length > 0 || p.simulations.length > 0
);
const categoryLabel =
  t.categoryLabels[data.category as keyof typeof t.categoryLabels] ?? data.category;
---

<Layout
  title={data.name}
  description={`${categoryLabel} enclosure: ${data.name}`}
  preloadData={hasCurves ? [`/api/curves/${entry.id}.json`] : []}
>
  <div class="detail">
    <header class="detail-header">
      <div class="header-top">
        <span class={`badge badge-${data.category}`}>{data.category}</span>
        <span class={`badge badge-${provenance}`}>{provenance}</span>
        {data.verified && <span class="badge badge-verified">{t.enclosureDetail.verified}</span>}
        <button
          id="detail-stack-btn"
          class="add-btn"
          data-slug={entry.id}
          data-label-add={t.catalogGrid.addToStack}
          data-label-done={t.catalogGrid.added}
        >{t.catalogGrid.addToStack}</button>
      </div>
      <h1 data-pagefind-meta="title">{data.name}</h1>
      <p class="meta">
        <a href={`${localeBase}/help#${data.topology}`} data-pagefind-filter="topology">{humanize(data.topology)}</a>
        {data.author && <> · {t.enclosureDetail.by} {data.author}</>}
        {data.revision && <> · {t.enclosureDetail.rev} {data.revision}</>}
        · <span class="muted">{data.license}</span>
        {availabilityLabel && <> · <span class:list={["availability", { "non-free": nonFree }]}>{availabilityLabel}</span></>}
      </p>
      <p class="meta" data-pagefind-filter="category">{data.category}</p>
      {data.recommendedFor.length > 0 && (
        <ul class="tag-list">
          {data.recommendedFor.map((tag) => <li class="tag">{tag}</li>)}
        </ul>
      )}
      {heroImage && (
        <Image
          src={heroImage}
          alt={data.name}
          widths={[400, 800, 1200]}
          sizes="(max-width: 900px) 100vw, 900px"
          loading="eager"
          fetchpriority="high"
          class="hero-img"
        />
      )}
    </header>

    <div class="detail-body">
      <section class="specs-section">
        <h2>{t.enclosureDetail.specifications}</h2>
        <table>
          <tbody>
            {specRows.map(({ label, value }) => value != null && (
              <tr><th scope="row">{label}</th><td>{value}</td></tr>
            ))}
          </tbody>
        </table>
      </section>

      <section class="drivers-section">
        <h2>{t.enclosureDetail.driversSection}</h2>
        {driverProfileTables.map((profile) => (
          <div class="driver-profile-table">
            <h3>
              {tt(t.enclosureDetail.profileHeading, {
                id: profile.id,
                n: profile.rows.reduce((sum, r) => sum + r.qty, 0),
              })}
            </h3>
            <table>
              <thead>
                <tr>
                  <th>{t.enclosureDetail.model}</th>
                  <th>{t.enclosureDetail.qty}</th>
                  <th>{t.enclosureDetail.format}</th>
                  <th>{t.enclosureDetail.impedance}</th>
                  <th>{t.enclosureDetail.fs}</th>
                  <th>{t.enclosureDetail.detail}</th>
                  <th>{t.enclosureDetail.pe}</th>
                  <th>{t.enclosureDetail.sensitivity}</th>
                </tr>
              </thead>
              <tbody>
                {profile.rows.map(({ entry: d, qty, horn }) => d && (
                  <tr>
                    <td>
                      <a href={`${localeBase}/drivers/${d.id}`}>{d.data.brand} {d.data.model}</a>
                      {horn && (
                        <div class="muted horn-link">
                          {t.enclosureDetail.viaHorn} <a href={`${localeBase}/horns/${horn.id}`}>{horn.data.brand} {horn.data.model}</a>
                        </div>
                      )}
                    </td>
                    <td>{qty}×</td>
                    {d.data.type === "cone" ? (
                      <>
                        <td>{d.data.sizeInch}"</td>
                        <td>{d.data.impedanceOhm} Ω</td>
                        <td>{d.data.fsHz} Hz</td>
                        <td>{tt(t.enclosureDetail.coneDetail, { qts: d.data.qts, vas: d.data.vasL, xmax: d.data.xmaxMm })}</td>
                        <td>{d.data.peW} W</td>
                        <td>{d.data.sensitivityDb} dB</td>
                      </>
                    ) : (
                      <>
                        <td>{d.data.exitInch}"{t.enclosureDetail.exitSuffix}</td>
                        <td>{d.data.impedanceOhm} Ω</td>
                        <td>{d.data.fsHz ? `${d.data.fsHz} Hz` : ""}</td>
                        <td>{tt(t.enclosureDetail.compDetail, { fLow: d.data.fLowHz, fHigh: d.data.fHighHz, minXo: d.data.minCrossoverHz })}</td>
                        <td>{d.data.peW} W</td>
                        <td>{d.data.sensitivityHornDb} dB</td>
                      </>
                    )}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ))}
      </section>

      {hasCurves && (
        <section class="curves-section">
          <h2>{t.enclosureDetail.measurementsSims}</h2>
          <BoxCurves client:only="svelte" slug={entry.id} name={data.name} t={t.boxCurves} curveLabels={t.curveLabels} />
        </section>
      )}

      {data.images.length > 0 && (
        <section class="images-section">
          <h2>{t.enclosureDetail.images}</h2>
          <div class="image-gallery">
            {data.images.map((img, i) => (
              <button
                type="button"
                class="lightbox-trigger"
                data-lightbox-index={i}
                aria-label={tt(t.enclosureDetail.openImage, { n: i + 1, total: data.images.length })}
              >
                <Image
                  src={img}
                  alt={i === 0 ? data.name : tt(t.enclosureDetail.photoAlt, { name: data.name, n: i + 1 })}
                  widths={[400, 800, 1200]}
                  sizes="(max-width: 600px) 100vw, (max-width: 1200px) 50vw, 400px"
                  loading="lazy"
                  class="gallery-img"
                />
              </button>
            ))}
          </div>
        </section>
      )}

      {data.images.length > 0 && (
        <dialog
          id="lightbox"
          class="lightbox"
          aria-label={t.enclosureDetail.images}
          data-images={JSON.stringify(lightboxImages)}
          data-counter-format={t.enclosureDetail.imageCounter}
        >
          <button type="button" class="lightbox-close" aria-label={t.enclosureDetail.closeImage}>&times;</button>
          <button type="button" class="lightbox-prev" aria-label={t.enclosureDetail.previousImage}>&lsaquo;</button>
          <img class="lightbox-img" src="" alt="" />
          <button type="button" class="lightbox-next" aria-label={t.enclosureDetail.nextImage}>&rsaquo;</button>
          <p class="lightbox-counter" aria-live="polite"></p>
        </dialog>
      )}

      {planUrls.length > 0 && (
        <section class="plans-section">
          <h2>{t.enclosureDetail.plans}</h2>
          <ul class="plan-list">
            {planUrls.map(({ filename, url }) => (
              <li>
                {url
                  ? <a href={url} download={filename}>{filename}</a>
                  : <span class="muted">{filename} (not found)</span>}
              </li>
            ))}
          </ul>
        </section>
      )}

      {sourceFiles.length > 0 && (
        <section class="plans-section">
          <h2>{t.enclosureDetail.sources}</h2>
          <ul class="plan-list">
            {sourceFiles.map(({ tool, file, note, url }) => (
              <li>
                {url
                  ? <a href={url} download={file}>{file}</a>
                  : <span class="muted">{file} (not found)</span>}
                <span class="muted"> · {tool}{note ? ` · ${note}` : ""}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      {relatedEnclosures.length > 0 && (
        <section class="related-section">
          <h2>{t.enclosureDetail.relatedEnclosures}</h2>
          <EnclosureList items={relatedEnclosures} />
        </section>
      )}

      {contactList.length > 0 && (
        <section class="plans-section">
          <h2>{contactHeading}</h2>
          <ul class="plan-list">
            {contactList.map((c) => {
              const href = contactHref(c.channel, c.value);
              const label = contactLabel(c.value);
              const channelLabel = contactChannels[c.channel as keyof typeof contactChannels] ?? c.channel;
              return (
                <li>
                  <span class="muted">{channelLabel}:</span>{" "}
                  {href
                    ? <a href={href} target="_blank" rel="noopener">{label}</a>
                    : <span>{label}</span>}
                  {c.note ? <span class="muted"> · {c.note}</span> : ""}
                </li>
              );
            })}
          </ul>
        </section>
      )}

      {data.sourceUrl && (
        <p class="source-url">
          Source: <a href={data.sourceUrl} target="_blank" rel="noopener">{data.sourceUrl}</a>
        </p>
      )}

      <section class="notes-section">
        <h2>Notes</h2>
        <div class="notes-body">
          <Content />
        </div>
      </section>
    </div>
  </div>
</Layout>

<script>
  import { decodeStack, encodeStack } from "../../../lib/stack";

  const btn = document.getElementById("detail-stack-btn") as HTMLButtonElement | null;
  if (btn) {
    btn.addEventListener("click", () => {
      try {
        const slug = btn.dataset.slug!;
        const raw = localStorage.getItem("boxdex-stack") ?? "";
        const { state, cov, xo } = decodeStack(raw);
        if (!state.some((s) => s.slug === slug)) {
          localStorage.setItem(
            "boxdex-stack",
            encodeStack([...state, { slug, qty: 1 }], cov, xo)
          );
        }
      } catch (_) {}
      const labelDone = btn.dataset.labelDone!;
      const labelAdd = btn.dataset.labelAdd!;
      btn.textContent = labelDone;
      btn.classList.add("add-btn-done");
      setTimeout(() => {
        btn.textContent = labelAdd;
        btn.classList.remove("add-btn-done");
      }, 1200);
    });
  }

  const dialog = document.getElementById("lightbox") as HTMLDialogElement | null;
  if (dialog) {
    const images = JSON.parse(dialog.dataset.images ?? "[]") as { src: string; alt: string }[];
    const counterFormat = dialog.dataset.counterFormat ?? "{n} / {total}";
    const imgEl = dialog.querySelector(".lightbox-img") as HTMLImageElement;
    const counterEl = dialog.querySelector(".lightbox-counter") as HTMLElement;
    const closeBtn = dialog.querySelector(".lightbox-close") as HTMLButtonElement;
    const prevBtn = dialog.querySelector(".lightbox-prev") as HTMLButtonElement;
    const nextBtn = dialog.querySelector(".lightbox-next") as HTMLButtonElement;
    let current = 0;
    // Matches --transition-fast (the .lightbox-img opacity transition below): the src
    // swap happens mid-fade so the crossfade covers the (near-instant) image change.
    const FADE_MS = 100;
    let fadeTimer: ReturnType<typeof setTimeout> | undefined;

    const show = (index: number) => {
      current = (index + images.length) % images.length;
      const img = images[current];
      counterEl.textContent = counterFormat
        .replace("{n}", String(current + 1))
        .replace("{total}", String(images.length));
      const multi = images.length > 1;
      prevBtn.hidden = !multi;
      nextBtn.hidden = !multi;

      clearTimeout(fadeTimer);
      imgEl.classList.add("is-fading");
      fadeTimer = setTimeout(() => {
        imgEl.src = img.src;
        imgEl.alt = img.alt;
        imgEl.classList.remove("is-fading");
      }, FADE_MS);
    };

    document.querySelectorAll<HTMLButtonElement>(".lightbox-trigger").forEach((trigger) => {
      trigger.addEventListener("click", () => {
        show(Number(trigger.dataset.lightboxIndex ?? "0"));
        dialog.showModal();
      });
    });

    closeBtn.addEventListener("click", () => dialog.close());
    prevBtn.addEventListener("click", () => show(current - 1));
    nextBtn.addEventListener("click", () => show(current + 1));

    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });

    dialog.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft") show(current - 1);
      else if (e.key === "ArrowRight") show(current + 1);
    });
  }
</script>

<style>
  .detail-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--line);
  }

  .header-top {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .header-top .add-btn {
    margin-left: auto;
  }

  .add-btn {
    background: none;
    border: 1px solid var(--line);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.35rem 0.9rem;
    border-radius: 3px;
    cursor: pointer;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .add-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .add-btn-done {
    border-color: var(--accent);
    color: var(--accent);
  }

  h1 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-size: 1.1rem;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .driver-profile-table h3 {
    font-size: 0.95rem;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .driver-profile-table + .driver-profile-table {
    margin-top: 1.5rem;
  }

  .horn-link {
    font-size: 0.8rem;
    margin-top: 0.15rem;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0.25rem 0;
    text-transform: capitalize;
  }

  /* --accent and --muted are near-identical luminance in light theme: underline keeps
     the topology link distinguishable from the surrounding muted text (WCAG 1.4.1). */
  .meta a {
    text-decoration: underline;
  }

  .availability {
    color: var(--text);
  }

  .availability.non-free {
    color: var(--accent);
    font-weight: 600;
  }

  .detail-body {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .lightbox-trigger {
    all: unset;
    display: block;
    width: 100%;
    cursor: zoom-in;
  }

  .lightbox-trigger:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  :global(.hero-img) {
    width: 100%;
    height: auto;
    margin-top: 1.25rem;
    border-radius: 4px;
    border: 1px solid var(--line);
  }

  .image-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }

  :global(.gallery-img) {
    width: 100%;
    height: auto;
    border-radius: 4px;
    border: 1px solid var(--line);
  }

  .lightbox {
    border: none;
    padding: 0;
    background: transparent;
    max-width: 95vw;
    max-height: 95vh;
    width: min(1400px, 95vw);
    overscroll-behavior: contain;
  }

  .lightbox::backdrop {
    background: color-mix(in srgb, black 85%, transparent);
  }

  .lightbox-img {
    display: block;
    width: 100%;
    height: 90vh;
    object-fit: contain;
    opacity: 1;
    transition: opacity var(--transition-fast) ease;
  }

  .lightbox-img.is-fading {
    opacity: 0;
  }

  .lightbox-close,
  .lightbox-prev,
  .lightbox-next {
    position: fixed;
    background: color-mix(in srgb, var(--bg) 70%, transparent);
    border: 1px solid var(--line);
    color: var(--text);
    border-radius: var(--radius-lg, 6px);
    cursor: pointer;
    font-size: 1.5rem;
    line-height: 1;
    padding: 0.4rem 0.75rem;
  }

  .lightbox-close:hover,
  .lightbox-prev:hover,
  .lightbox-next:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .lightbox-close {
    top: 1rem;
    right: 1rem;
  }

  .lightbox-prev,
  .lightbox-next {
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox-prev {
    left: 1rem;
  }

  .lightbox-next {
    right: 1rem;
  }

  .lightbox-counter {
    position: fixed;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    background: color-mix(in srgb, var(--bg) 70%, transparent);
