---
import Explorer from "../../components/Explorer.svelte";
import Layout from "../../components/Layout.astro";
import { localeStaticPaths, useLocale } from "../../i18n";

export { localeStaticPaths as getStaticPaths };

const { t, localeBase } = useLocale(Astro.params);
---

<Layout
  title={t.pages.find.title}
  description={t.pages.find.description}
  preloadData={["/api/manifest.json"]}
>
  <h1>{t.pages.find.heading}</h1>
  <p class="subtitle">{t.pages.find.subtitle}</p>
  <Explorer client:only="svelte" t={t.explorer} localeBase={localeBase} axisLabels={t.axisLabels} />
</Layout>

<style>
  h1 { margin-bottom: 0.5rem; }
  .subtitle {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }
</style>
