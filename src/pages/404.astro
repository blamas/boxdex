---
import NotFound from "../components/NotFound.astro";
import { DEFAULT_LOCALE } from "../i18n";

// Root-level 404 (not under [locale]): Astro emits dist/404.html. The Worker
// serves it for unmatched paths outside any locale prefix, locale-prefixed
// misses get the per-locale page in src/pages/[locale]/404.astro instead.
---

<NotFound locale={DEFAULT_LOCALE} />
