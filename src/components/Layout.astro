---
import { getRelativeLocaleUrl } from "astro:i18n";
import { ClientRouter } from "astro:transitions";
import Search from "astro-pagefind/components/Search.astro";
import { DEFAULT_LOCALE, LOCALES, useTranslations } from "../i18n";
import { AUTH_ENABLED, AUTH_HASHES } from "../lib/auth";
import { BASE } from "../lib/site";

interface Props {
  title: string;
  description?: string;
  // BASE-relative JSON endpoints the page's island fetches on mount; preloaded from
  // the head so the data downloads in parallel with the island JS instead of after it.
  preloadData?: string[];
}

const { title, description = "Open enclosure plans database", preloadData = [] } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const locale = Astro.currentLocale ?? DEFAULT_LOCALE;
const t = useTranslations(locale);

// Strip BASE then locale prefix to get the path for the language switcher.
// Lookahead (?=/|$) prevents matching a locale code that prefixes the next path segment.
const baselessPath = Astro.url.pathname.startsWith(BASE)
  ? Astro.url.pathname.slice(BASE.length)
  : Astro.url.pathname;
const rawPath = baselessPath.replace(new RegExp(`^/${locale}(?=/|$)`), "") || "/";
const allLocales = LOCALES.map((l) => ({
  code: l,
  url: getRelativeLocaleUrl(l, rawPath),
}));

function navHref(path: string) {
  return getRelativeLocaleUrl(locale, path);
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Boxdex</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href={`${BASE}/sitemap-index.xml`} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    {preloadData.map((p: string) => <link rel="preload" href={`${BASE}${p}`} as="fetch" crossorigin="anonymous" />)}
    <ClientRouter />
    <!-- Apply saved theme before first paint and after each ClientRouter swap -->
    <script is:inline data-astro-rerun>
      (function () {
        try {
          var t = localStorage.getItem("boxdex-theme");
          if (t === "light" || (!t && !window.matchMedia("(prefers-color-scheme: dark)").matches)) {
            document.documentElement.dataset.theme = "light";
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    {AUTH_ENABLED && AUTH_HASHES.length > 0 && (
      <div id="boxdex-gate" transition:persist style="display:none;position:fixed;inset:0;z-index:9999;background:var(--bg,#111);align-items:center;justify-content:center;">
        <form id="boxdex-gate-form" style="display:flex;flex-direction:column;gap:1rem;align-items:center;font-family:var(--font-mono,monospace);min-width:18rem;">
          <p style="margin:0;color:var(--muted,#888);font-size:0.875rem;">This site is under construction.</p>
          <input id="boxdex-gate-input" type="password" placeholder="Password" autocomplete="current-password"
            style="width:100%;padding:0.5rem 0.75rem;border:1px solid var(--line,#444);background:var(--panel,#222);color:var(--text,#eee);font-family:inherit;border-radius:4px;font-size:1rem;box-sizing:border-box;" />
          <button type="submit"
            style="width:100%;padding:0.5rem;border:1px solid var(--accent,#7aa2f7);background:transparent;color:var(--accent,#7aa2f7);font-family:inherit;border-radius:4px;cursor:pointer;font-size:0.875rem;">Enter</button>
          <p id="boxdex-gate-error" style="margin:0;color:#f7768e;font-size:0.8rem;min-height:1em;"></p>
        </form>
      </div>
    )}
    {AUTH_ENABLED && AUTH_HASHES.length > 0 && (
      <script is:inline define:vars={{ authHashes: AUTH_HASHES }} data-astro-rerun>
        (function () {
          var gate = document.getElementById("boxdex-gate");
          if (!gate) return;
          var KEY = "boxdex-auth";
          if (sessionStorage.getItem(KEY) === "1") return;
          gate.style.display = "flex";
          var form = document.getElementById("boxdex-gate-form");
          if (form._boxdexInit) return;
          form._boxdexInit = true;
          form.addEventListener("submit", async function (e) {
            e.preventDefault();
            var pwd = document.getElementById("boxdex-gate-input").value;
            var buf = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(pwd));
            var hex = Array.from(new Uint8Array(buf)).map(function (b) { return b.toString(16).padStart(2, "0"); }).join("");
            if (authHashes.includes(hex)) {
              sessionStorage.setItem(KEY, "1");
              gate.style.display = "none";
            } else {
              document.getElementById("boxdex-gate-error").textContent = "Incorrect password.";
              document.getElementById("boxdex-gate-input").value = "";
            }
          });
        })();
      </script>
    )}
    <header data-pagefind-ignore transition:persist>
      <div class="container">
        <nav>
          <a class="site-title" href={navHref("/")}>Boxdex</a>
          <span class="nav-sep">·</span>
          <div class="nav-links">
            <a href={navHref("/")}>{t.nav.catalog}</a>
            <a href={navHref("/compare")}>{t.nav.compare}</a>
            <a href={navHref("/explore")}>{t.nav.explore}</a>
            <a href={navHref("/find")}>{t.nav.find}</a>
            <a href={navHref("/stack")}>{t.nav.stack}</a>
            <a href={navHref("/drivers")}>{t.nav.drivers}</a>
          </div>
          <div class="search-bar">
            <Search />
          </div>
          <select id="locale-select" aria-label="Language">
            {allLocales.map(({ code, url }) => (
              <option value={url} selected={code === locale}>{code.toUpperCase()}</option>
            ))}
          </select>
          <a class="help-btn" href={navHref("/help")} aria-label={t.nav.helpLabel} title={t.nav.helpLabel}>?</a>
          <button id="theme-toggle" aria-label={t.nav.toggleTheme} title={t.nav.toggleTheme}>
            <span class="icon-dark">◑</span>
            <span class="icon-light">◐</span>
          </button>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer data-pagefind-ignore>
      <div class="container">
        <p>{t.footer.text}</p>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var sel = document.getElementById("locale-select");
        if (sel && !sel._boxdexInit) {
          sel._boxdexInit = true;
          sel.addEventListener("change", function () { window.location.href = this.value + window.location.search; });
        }
        var btn = document.getElementById("theme-toggle");
        if (!btn || btn._boxdexInit) return;
        btn._boxdexInit = true;
        btn.addEventListener("click", function () {
          var html = document.documentElement;
          var next = html.dataset.theme === "light" ? "dark" : "light";
          if (next === "dark") {
            delete html.dataset.theme;
          } else {
            html.dataset.theme = "light";
          }
          try { localStorage.setItem("boxdex-theme", next); } catch (_) {}
          document.dispatchEvent(new CustomEvent("boxdex:themechange", { detail: { theme: next } }));
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  :root {
    --pf-text: var(--text);
    --pf-text-secondary: var(--muted);
    --pf-text-muted: var(--muted);
    --pf-background: var(--bg);
    --pf-border: var(--line);
    --pf-border-focus: var(--accent);
    --pf-skeleton: var(--panel);
    --pf-skeleton-shine: var(--line);
    --pf-hover: var(--panel);
    --pf-mark: var(--accent);
    --pf-outline-focus: var(--accent);
    --pf-font: var(--font-mono);
  }
</style>

<style>
  header {
    border-bottom: 1px solid var(--line);
    padding: 0.75rem 0;
    margin-bottom: 2rem;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .site-title {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
  }

  .nav-sep {
    color: var(--text);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1;
  }

  .nav-links {
    margin-right: auto;
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  .nav-links a {
    color: var(--text);
  }

  .nav-links a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  #locale-select,
  .help-btn,
  #theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--pf-border, var(--line));
    border-radius: 4px;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    height: var(--pf-input-height, 36px);
    width: var(--pf-input-height, 36px);
    padding: 0;
    cursor: pointer;
    line-height: 1;
    text-decoration: none;
  }

  #locale-select {
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    padding: 0;
    width: var(--pf-input-height, 36px);
    text-align: center;
    appearance: none;
  }

  #locale-select:hover,
  .help-btn:hover,
  #theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }


  /* Show the right icon based on current theme */
  :root:not([data-theme="light"]) .icon-light { display: none; }
  [data-theme="light"] .icon-dark { display: none; }

  .search-bar {
    flex: 1;
    max-width: 20rem;
    min-width: 10rem;
  }

  footer {
    border-top: 1px solid var(--line);
    margin-top: 3rem;
    padding: 1.5rem 0;
    color: var(--muted);
    font-size: 0.8rem;
    text-align: center;
  }

  main {
    padding-top: 0;
    padding-bottom: 3rem;
    position: relative;
  }
</style>
