---
import { DEFAULT_LOCALE, tt, useTranslations } from "../i18n";
import type { Driver } from "../lib/schemas";
import type { SubstituteCandidate } from "../lib/similarity";
import { BASE } from "../lib/site";

interface Props {
  target: Driver;
  candidates: SubstituteCandidate[];
}

const { target, candidates } = Astro.props;
const columns = candidates[0]?.deltas ?? [];

const locale = Astro.currentLocale ?? DEFAULT_LOCALE;
const t = useTranslations(locale);
const tsl = t.substituteList;
const localeBase = `${BASE}/${locale}`;

const compareUrl = (ids: string[]) => `${localeBase}/drivers/compare?ids=${ids.join(",")}`;

function fmtDelta(candidate: number, target: number): string {
  const diff = Math.round((candidate - target) * 100) / 100;
  if (diff === 0) return "=";
  return diff > 0 ? `+${diff}` : String(diff);
}
---

{candidates.length > 0 ? (
  <>
    <table>
      <thead>
        <tr>
          <th>{tsl.driver}</th>
          {columns.map((c) => <th>{c.label}{c.unit && ` (${c.unit})`}</th>)}
          <th>{tsl.fit}</th>
          <th>{tsl.notes}</th>
          <th>{tsl.compare}</th>
        </tr>
      </thead>
      <tbody>
        {candidates.map((c) => (
          <tr>
            <td>
              <a href={`${localeBase}/drivers/${c.driver.id}`}>{c.driver.brand} {c.driver.model}</a>
            </td>
            {c.deltas.map((d) => (
              <td>{d.candidate} <span class="delta">{fmtDelta(d.candidate, d.target)}</span></td>
            ))}
            <td><span class={`tier tier-${c.tier}`}>{c.tier}</span></td>
            <td class="notes">{c.flags.join(" · ")}</td>
            <td class="compare-cell">
              <a class="compare-link" href={compareUrl([target.id, c.driver.id])} title={tt(tsl.compareTitle, { model1: target.model, model2: c.driver.model })} aria-label={tt(tsl.compareTitle, { model1: target.model, model2: c.driver.model })}>+</a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="compare-all">
      <a href={compareUrl([target.id, ...candidates.slice(0, 3).map((c) => c.driver.id)])}>{tt(tsl.compareClosest, { n: Math.min(3, candidates.length), model: target.model })}</a>
    </p>
    <p class="provenance-note">
      {target.type === "cone" ? tsl.provenanceNoteCone : tsl.provenanceNoteComp}
    </p>
  </>
) : (
  <p class="muted">
    {target.type === "cone"
      ? tt(tsl.emptyCone, { size: target.sizeInch })
      : tt(tsl.emptyComp, { size: target.exitInch })}
  </p>
)}

<style>
  .delta {
    color: var(--muted);
    font-size: 0.75em;
  }

  .tier {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.1rem 0.45rem;
    border-radius: 3px;
    border: 1px solid currentColor;
  }

  .tier-close {
    color: var(--accent);
  }

  .tier-usable {
    color: var(--accent-2);
  }

  .tier-risky {
    color: var(--danger);
  }

  .notes {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .compare-cell {
    text-align: center;
  }

  .compare-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1;
    padding: 0.15rem 0.45rem;
    border: 1px solid var(--line);
    border-radius: 3px;
    text-decoration: none;
  }

  .compare-link:hover {
    border-color: var(--accent);
  }

  .compare-all {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin: 0.75rem 0 0;
  }

  .muted {
    color: var(--muted);
  }
</style>
