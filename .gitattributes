# Normalize line endings to LF
* text=auto eol=lf

# Explicit text types
*.ts       text eol=lf
*.astro    text eol=lf
*.svelte   text eol=lf
*.js       text eol=lf
*.mjs      text eol=lf
*.css      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.mdx      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf
*.csv      text eol=lf
*.txt      text eol=lf
*.svg      text eol=lf
*.sh       text eol=lf -crlf
.npmrc     text eol=lf
.node-version text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary

# Exclude bulk data + generated schema mirrors from Linguist stats/diffs
data/** linguist-generated=true
schema/*.schema.json linguist-generated=true
