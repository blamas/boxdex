{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "category": {
      "type": "string",
      "enum": ["sub", "kick", "mid", "top"]
    },
    "topology": {
      "type": "string",
      "enum": [
        "sealed",
        "bass_reflex",
        "bandpass",
        "tapped_horn",
        "front_loaded_horn",
        "folded_horn",
        "scoop",
        "transmission_line"
      ]
    },
    "driverProfiles": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "drivers": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "driver": {
                  "anyOf": [
                    {
                      "type": "number"
                    },
                    {
                      "type": "string"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "collection": {
                          "type": "string"
                        }
                      },
                      "required": ["id", "collection"]
                    },
                    {
                      "type": "object",
                      "properties": {
                        "slug": {
                          "type": "string"
                        },
                        "collection": {
                          "type": "string"
                        }
                      },
                      "required": ["slug", "collection"]
                    }
                  ]
                },
                "qty": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "horn": {
                  "anyOf": [
                    {
                      "type": "number"
                    },
                    {
                      "type": "string"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "collection": {
                          "type": "string"
                        }
                      },
                      "required": ["id", "collection"]
                    },
                    {
                      "type": "object",
                      "properties": {
                        "slug": {
                          "type": "string"
                        },
                        "collection": {
                          "type": "string"
                        }
                      },
                      "required": ["slug", "collection"]
                    }
                  ]
                }
              },
              "required": ["driver", "qty"]
            }
          },
          "simulations": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "source": {
                  "type": "string",
                  "enum": [
                    "hornresp_sim",
                    "akabak_sim",
                    "catt_sim",
                    "vituixcad_sim",
                    "winsd_sim",
                    "basta_sim"
                  ]
                },
                "curves": {
                  "default": {},
                  "type": "object",
                  "properties": {
                    "spl": {
                      "type": "object",
                      "properties": {
                        "file": {
                          "type": "string",
                          "pattern": ".*\\.csv$"
                        },
                        "note": {
                          "type": "string"
                        }
                      },
                      "required": ["file"]
                    },
                    "phase": {
                      "type": "object",
                      "properties": {
                        "file": {
                          "type": "string",
                          "pattern": ".*\\.csv$"
                        },
                        "note": {
                          "type": "string"
                        }
                      },
                      "required": ["file"]
                    },
                    "impedance": {
                      "type": "object",
                      "properties": {
                        "file": {
                          "type": "string",
                          "pattern": ".*\\.csv$"
                        },
                        "note": {
                          "type": "string"
                        }
                      },
                      "required": ["file"]
                    },
                    "group_delay": {
                      "type": "object",
                      "properties": {
                        "file": {
                          "type": "string",
                          "pattern": ".*\\.csv$"
                        },
                        "note": {
                          "type": "string"
                        }
                      },
                      "required": ["file"]
                    },
                    "distortion": {
                      "type": "object",
                      "properties": {
                        "file": {
                          "type": "string",
                          "pattern": ".*\\.csv$"
                        },
                        "note": {
                          "type": "string"
                        }
                      },
                      "required": ["file"]
                    },
                    "power_compression": {
                      "type": "object",
                      "properties": {
                        "file": {
                          "type": "string",
                          "pattern": ".*\\.csv$"
                        },
                        "note": {
                          "type": "string"
                        }
                      },
                      "required": ["file"]
                    }
                  }
                },
                "stacked": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "count": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "file": {
                        "type": "string",
                        "pattern": ".*\\.csv$"
                      },
                      "note": {
                        "type": "string"
                      }
                    },
                    "required": ["count", "file"]
                  }
                }
              },
              "required": ["id", "source"]
            }
          },
          "measurements": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "source": {
                  "type": "string",
                  "enum": ["rew_measured", "klippel"]
                },
                "curves": {
                  "default": {},
                  "type": "object",
                  "properties": {
                    "spl": {
                      "type": "object",
                      "properties": {
                        "file": {
                          "type": "string",
                          "pattern": ".*\\.csv$"
                        },
                        "note": {
                          "type": "string"
                        }
                      },
                      "required": ["file"]
                    },
                    "phase": {
                      "type": "object",
                      "properties": {
                        "file": {
                          "type": "string",
                          "pattern": ".*\\.csv$"
                        },
                        "note": {
                          "type": "string"
                        }
                      },
                      "required": ["file"]
                    },
                    "impedance": {
                      "type": "object",
                      "properties": {
                        "file": {
                          "type": "string",
                          "pattern": ".*\\.csv$"
                        },
                        "note": {
                          "type": "string"
                        }
                      },
                      "required": ["file"]
                    },
                    "group_delay": {
                      "type": "object",
                      "properties": {
                        "file": {
                          "type": "string",
                          "pattern": ".*\\.csv$"
                        },
                        "note": {
                          "type": "string"
                        }
                      },
                      "required": ["file"]
                    },
                    "distortion": {
                      "type": "object",
                      "properties": {
                        "file": {
                          "type": "string",
                          "pattern": ".*\\.csv$"
                        },
                        "note": {
                          "type": "string"
                        }
                      },
                      "required": ["file"]
                    },
                    "power_compression": {
                      "type": "object",
                      "properties": {
                        "file": {
                          "type": "string",
                          "pattern": ".*\\.csv$"
                        },
                        "note": {
                          "type": "string"
                        }
                      },
                      "required": ["file"]
                    }
                  }
                },
                "stacked": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "count": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "file": {
                        "type": "string",
                        "pattern": ".*\\.csv$"
                      },
                      "note": {
                        "type": "string"
                      }
                    },
                    "required": ["count", "file"]
                  }
                }
              },
              "required": ["id", "source"]
            }
          }
        },
        "required": ["id", "drivers"]
      }
    },
    "netVolumeL": {
      "type": "number",
      "minimum": 0.01,
      "maximum": 50000
    },
    "dims": {
      "type": "object",
      "properties": {
        "hMm": {
          "type": "number",
          "minimum": 10,
          "maximum": 10000
        },
        "wMm": {
          "type": "number",
          "minimum": 10,
          "maximum": 10000
        },
        "dMm": {
          "type": "number",
          "minimum": 10,
          "maximum": 10000
        }
      },
      "required": ["hMm", "wMm", "dMm"]
    },
    "weightKg": {
      "type": "number",
      "minimum": 0.1,
      "maximum": 5000
    },
    "specs": {
      "type": "object",
      "properties": {
        "f3Hz": {
          "type": "number",
          "minimum": 1,
          "maximum": 20000
        },
        "f3HzHigh": {
          "type": "number",
          "minimum": 1,
          "maximum": 20000
        },
        "f6Hz": {
          "type": "number",
          "minimum": 1,
          "maximum": 20000
        },
        "fbHz": {
          "type": "number",
          "minimum": 1,
          "maximum": 20000
        },
        "maxSplDb": {
          "type": "number",
          "minimum": 50,
          "maximum": 200
        },
        "maxSplExcursionDb": {
          "type": "number",
          "minimum": 50,
          "maximum": 200
        },
        "maxSplThermalDb": {
          "type": "number",
          "minimum": 50,
          "maximum": 200
        },
        "sensitivityDb": {
          "type": "number",
          "minimum": 30,
          "maximum": 150
        },
        "impedanceMinOhm": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 1000
        },
        "impedanceNominalOhm": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 1000
        },
        "recommendedPowerW": {
          "type": "number",
          "minimum": 1,
          "maximum": 1000000
        },
        "powerAesW": {
          "type": "number",
          "minimum": 1,
          "maximum": 1000000
        },
        "powerProgramW": {
          "type": "number",
          "minimum": 1,
          "maximum": 1000000
        },
        "coverageAngleDeg": {
          "type": "number",
          "minimum": 1,
          "maximum": 360
        },
        "recommendedCrossoverHz": {
          "type": "number",
          "minimum": 1,
          "maximum": 20000
        },
        "hornCutoffHz": {
          "type": "number",
          "minimum": 1,
          "maximum": 20000
        },
        "hornMouthCm2": {
          "type": "number",
          "minimum": 1,
          "maximum": 1000000
        },
        "hornThroatCm2": {
          "type": "number",
          "minimum": 1,
          "maximum": 1000000
        },
        "maxVelocityMs": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 343
        }
      },
      "required": ["f3Hz"]
    },
    "sources": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tool": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        },
        "required": ["tool", "file"]
      }
    },
    "images": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "plans": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "pattern": ".*\\.pdf$"
      }
    },
    "author": {
      "type": "string"
    },
    "sourceUrl": {
      "type": "string",
      "format": "uri"
    },
    "availability": {
      "type": "string",
      "enum": ["free", "paid", "contact", "commission", "out_of_print"]
    },
    "contact": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "enum": ["email", "website", "profile"]
          },
          "value": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string"
          }
        },
        "required": ["channel", "value"]
      }
    },
    "ways": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4
    },
    "revision": {
      "type": "string"
    },
    "license": {
      "type": "string",
      "enum": [
        "CC0-1.0",
        "CC-BY-4.0",
        "CC-BY-SA-4.0",
        "CC-BY-NC-4.0",
        "CC-BY-NC-SA-4.0",
        "CC-BY-NC-ND-4.0",
        "LicenseRef-Permission",
        "LicenseRef-Proprietary"
      ]
    },
    "licenseNote": {
      "type": "string"
    },
    "recommendedFor": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "techno",
          "tekno",
          "hardtek",
          "frenchcore",
          "hardcore",
          "acid",
          "hardstyle",
          "tribe",
          "raggatek",
          "mental",
          "dub",
          "psytrance",
          "breakcore",
          "bass_music"
        ]
      }
    },
    "verified": {
      "default": false,
      "type": "boolean"
    },
    "buildComplexity": {
      "type": "string",
      "enum": ["simple", "moderate", "complex"]
    },
    "topologyVariant": {
      "type": "string"
    },
    "connectors": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["speakON NL2", "speakON NL4", "speakON NL8", "XLR", "binding post", "jack 6.35mm"]
      }
    },
    "grossVolumeL": {
      "type": "number",
      "minimum": 0.01,
      "maximum": 50000
    },
    "plywoodThicknessMm": {
      "type": "number",
      "minimum": 1,
      "maximum": 100
    },
    "sheetCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "sheetSizeMm": {
      "type": "object",
      "properties": {
        "wMm": {
          "type": "number",
          "minimum": 100,
          "maximum": 10000
        },
        "hMm": {
          "type": "number",
          "minimum": 100,
          "maximum": 10000
        }
      },
      "required": ["wMm", "hMm"]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "category",
    "topology",
    "driverProfiles",
    "netVolumeL",
    "dims",
    "specs",
    "license"
  ]
}
