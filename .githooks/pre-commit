#!/bin/sh
# Fast local feedback for data contributors: only runs when staged files touch data/.
# Driver/horn files get a targeted single-file check; enclosure changes need the full
# `astro sync` (cross-file referential checks: dangling driver refs, license rules).
set -e

staged=$(git diff --cached --name-only --diff-filter=ACM)

drivers=$(echo "$staged" | grep -E '^data/drivers/.*\.json$' || true)
enclosures=$(echo "$staged" | grep -E '^data/enclosures/' || true)

if [ -z "$drivers" ] && [ -z "$enclosures" ]; then
  exit 0
fi

status=0

if [ -n "$drivers" ]; then
  for file in $drivers; do
    node scripts/validate-driver.mjs "$file" || status=1
  done
fi

if [ -n "$enclosures" ]; then
  echo "Enclosure files staged, running astro sync..."
  npx astro sync || status=1
fi

exit $status
